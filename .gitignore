# =============================================================
# asset-sut-system — Monorepo .gitignore
# =============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js (apps/frontend) ───────────────────────────────────
apps/frontend/.next/
apps/frontend/out/
apps/frontend/next-env.d.ts

# ── Build outputs ─────────────────────────────────────────────
build/
dist/
out/
.output/

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ── Environment variables ─────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor & OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json
.idea/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Vercel / Cloud deploys ────────────────────────────────────
.vercel

# ── Infra secrets (never commit) ──────────────────────────────
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/.terraform/
infra/**/*.auto.tfvars
infra/**/secrets.*
